{
  "name": "debughub",
  "version": "1.1.0",
  "description": "Cross-platform CLI tool for agent-agnostic deterministic debug logging",
  "main": "dist/cli.js",
  "bin": {
    "debughub": "dist/cli.js"
  },
  "files": [
    "dist/**",
    "docs/**",
    "README.md"
  ],
  "scripts": {
    "build": "node ./node_modules/typescript/bin/tsc && node scripts/build.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "npm run test:unit",
    "test:unit": "jest --testPathIgnorePatterns=tests/helpers/runtime.e2e.test.ts",
    "test:helpers:e2e": "jest tests/helpers/runtime.e2e.test.ts --runInBand",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "debugging",
    "agents",
    "cursor",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0"
  }
}
