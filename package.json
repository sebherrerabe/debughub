{
  "name": "debughub",
  "version": "1.0.0",
  "description": "Cross-platform CLI tool for agent-agnostic deterministic debug logging",
  "main": "dist/cli.js",
  "bin": {
    "debughub": "./dist/cli.js"
  },
  "scripts": {
    "build": "node ./node_modules/typescript/bin/tsc && node scripts/build.js",
    "test": "jest",
    "test:helpers:e2e": "jest tests/helpers/runtime.e2e.test.ts --runInBand",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "debugging",
    "agents",
    "cursor",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0"
  }
}
